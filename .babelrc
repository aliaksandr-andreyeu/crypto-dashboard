{
	"presets": [
		["@babel/preset-env", { "loose": true, "modules": false, "useBuiltIns": "usage" }],
		"@babel/preset-react"
	],
	"plugins": [
		"@babel/plugin-proposal-class-properties",
		"@babel/plugin-transform-object-assign",
		[
			"import",
			{
				"libraryName": "antd",
				"style": true
			}
		]
	]
}
